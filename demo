        String a = @"Data Source=(LocalDB)\MSSQLLocalDB;AttachDbFilename=|DataDirectory|student.mdf;Integrated Security=True";
        SqlConnection con = new SqlConnection(a);
        con.Open();

        String qry = "update stud set name=@name,age=@age where id=@id";
        SqlCommand cmd = new SqlCommand(qry, con);
        cmd.Parameters.AddWithValue("@name", TextBox1.Text);
