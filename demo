    {
        String a = @"Data Source=(LocalDB)\MSSQLLocalDB;AttachDbFilename=|DataDirectory|student.mdf;Integrated Security=True";
        SqlConnection con = new SqlConnection(a);
        con.Open();

        String qry = "INSERT INTO stud(name,age)VALUES(@name,@age)";
